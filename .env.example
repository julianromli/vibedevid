# VibeDev ID Environment Template
# Copy this file to `.env.local` for local development.
# In production, set the same keys in your deployment provider.
#
# Prefix guide:
# - VITE_* values are public and can be exposed to the browser.
# - Values without VITE_/NEXT_PUBLIC_ are server-only secrets. Never expose them client-side.

# -----------------------------------------------------------------------------
# Public client env (required for the Vite + Hono app)
# -----------------------------------------------------------------------------
# Supabase project URL and anon key are public by design; rely on RLS for data access.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Canonical public app URL. Use http://localhost:5173 locally and your production URL in production.
VITE_SITE_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Server-only secrets (required for production features)
# -----------------------------------------------------------------------------
# Supabase service role key bypasses RLS. Keep this secret and server-only.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Required for UploadThing uploads and file cleanup.
UPLOADTHING_TOKEN=your-uploadthing-token-here

# -----------------------------------------------------------------------------
# Optional server integrations
# -----------------------------------------------------------------------------
# Required only when AI completion/enhancement routes are enabled.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: increases GitHub import rate limits. Use either one.
GITHUB_TOKEN=your-github-token-here
# GH_TOKEN=your-github-token-here

# Optional: override dev/server port. Defaults to 5173.
# PORT=5173

# -----------------------------------------------------------------------------
# Compatibility aliases used by legacy Next.js files during the migration
# -----------------------------------------------------------------------------
# Keep these aligned with the VITE_* values while legacy app/ routes still exist.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Public auth redirect URL used by Supabase email/OAuth flows.
# Local example: http://localhost:5173
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Deployment-provided env (usually set automatically, do not hardcode locally)
# -----------------------------------------------------------------------------
# NODE_ENV=production
# VERCEL=1
# VERCEL_URL=your-preview.vercel.app
# VERCEL_PROJECT_PRODUCTION_URL=your-domain.com
# CI=true
