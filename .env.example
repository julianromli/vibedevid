# =============================================================================
# VibeDev ID — Environment Variables (TanStack Start + Vite + Nitro + Neon)
# =============================================================================
#
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# Vite loads `.env`, `.env.local`, and `.env.[mode]` automatically.
# Restart `bun run dev` after changing values.
#
# Public vs server-only:
# - `NEXT_PUBLIC_*` — read on server; also used by legacy helpers
# - `VITE_*`        — exposed to browser (preferred for client-side config)
# - no prefix       — server-only (never sent to browser)
# =============================================================================

# -----------------------------------------------------------------------------
# Required — Neon Postgres (database)
# Get from: Neon Dashboard → Connection Details → Connection string
# Use the pooled connection string for serverless/Workers
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Direct connection for migrations (optional, drizzle-kit)
# DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Supabase — only needed for one-time data migration script
# Use pooler URL (direct db.*.supabase.co may fail DNS on some networks)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# Set instead of passing --force when intentionally running destructive migration phases
# MIGRATE_CONFIRM=destroy

# -----------------------------------------------------------------------------
# Required — Better Auth
# -----------------------------------------------------------------------------

# Random secret (min 32 chars): openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_min_32_chars

# Public URL of this app (must match OAuth redirect URIs)
BETTER_AUTH_URL=http://localhost:3000

# Browser-exposed auth URL (same as BETTER_AUTH_URL in most setups)
VITE_BETTER_AUTH_URL=http://localhost:3000

# OAuth providers (Google + GitHub)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Email provider for verification + password reset (Resend)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Required — Site URL (SEO, auth redirects, OAuth callbacks)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3000
VITE_SITE_URL=http://localhost:3000

# OAuth callback URL (add to Google/GitHub OAuth app allowlist):
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/github

# -----------------------------------------------------------------------------
# File uploads — UploadThing
# Get from: https://uploadthing.com/dashboard
# Required for project/blog/avatar uploads; app returns 503 without it
# -----------------------------------------------------------------------------

UPLOADTHING_TOKEN=your_uploadthing_token

# Optional legacy UploadThing app ID (if your dashboard still shows it)
# UPLOADTHING_APP_ID=your_uploadthing_app_id

# -----------------------------------------------------------------------------
# AI features — OpenRouter
# Used by /api/ai/completion and /api/ai/enhance-description (blog editor)
# Get from: https://openrouter.ai/keys
# -----------------------------------------------------------------------------

OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# -----------------------------------------------------------------------------
# Optional — GitHub import
# Used by /api/github-import for higher rate limits when importing repos
# Create at: GitHub → Settings → Developer settings → Personal access tokens
# -----------------------------------------------------------------------------

# GITHUB_TOKEN=ghp_your_github_personal_access_token
# GH_TOKEN=ghp_your_github_personal_access_token

# -----------------------------------------------------------------------------
# Optional — Production / hosting (usually auto-set by platform)
# Do not set manually unless you know what you're doing
# -----------------------------------------------------------------------------

# Nitro production server (default: 3000)
# PORT=3000
# HOST=0.0.0.0

# -----------------------------------------------------------------------------
# CI / testing (set by CI runner, not needed locally)
# -----------------------------------------------------------------------------

# CI=true
