{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vibedevid",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2024-09-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public",
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
}
