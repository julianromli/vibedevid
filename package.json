    "lucide-react": "^0.562.0",
    "motion": "^12.23.12",
    "next-themes": "0.4.6",
    "novel": "^1.0.2",
    "react": "^19.2.3",
    "react-day-picker": "^9.9.0",
    "react-dom": "^19.2.3",
    "react-dropzone": "^14.3.8",
    "react-easy-crop": "^5.5.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.16.0",
    "react-use-measure": "^2.1.7",
