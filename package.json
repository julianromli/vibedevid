{
  "name": "trae-community-id",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build --mode server",
    "start": "bun --env=NODE_ENV=production ./dist/index.js",
    "preview": "vite preview",
    "lint": "bun scripts/lint-changed.mjs",
    "lint:fast": "bun scripts/lint-changed.mjs",
    "lint:all": "biome check src components lib hooks i18n tests scripts index.html vite.config.ts vitest.config.ts playwright.config.ts knip.json biome.json package.json components.json tsconfig.json",
    "lint:ci": "biome check src components lib hooks i18n tests scripts index.html vite.config.ts vitest.config.ts playwright.config.ts knip.json biome.json package.json components.json tsconfig.json --error-on-warnings",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "bun run test && bun run test:e2e",
    "generate:rpc": "bun scripts/generate-rpc-client.mjs",
    "analyze:dead-code": "knip",
    "analyze:deps": "depcheck"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.5",
    "@better-upload/client": "^3.0.6",
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.26.0",
    "@hono/zod-validator": "^0.8.0",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@radix-ui/react-alert-dialog": "latest",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "latest",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-collapsible": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-popover": "latest",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
